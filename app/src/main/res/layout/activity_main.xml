<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1923"
    android:fillViewport="true"
    tools:context="com.yhonam.penguinui.demo.MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- ══════════════ HEADER ══════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A2535"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="48dp"
            android:paddingBottom="24dp"
            android:paddingHorizontal="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐧 Penguin UI"
                android:textColor="#00D9FF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Demo interactiva de todos los componentes"
                android:textColor="#B0B0B0"
                android:textSize="13sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- ══════════════ SECCIÓN: TOASTS ══════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:text="PENGUIN TOAST"
            android:textColor="#00D9FF"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="16dp"
            android:background="#1A2535"
            android:layout_marginHorizontal="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnToastSuccess"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:backgroundTint="#00FF88"
                    android:text="Éxito"
                    android:textColor="#0F1923"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnToastError"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:backgroundTint="#FF2E63"
                    android:text="Error"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnToastWarning"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:backgroundTint="#FFB703"
                    android:text="Advertencia"
                    android:textColor="#0F1923"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnToastInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:backgroundTint="#00D9FF"
                    android:text="Info"
                    android:textColor="#0F1923"
                    android:textStyle="bold" />
            </LinearLayout>

            <Button
                android:id="@+id/btnToastCustom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="#7B2CBF"
                android:text="Éxito con título personalizado"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ══════════════ SECCIÓN: TOAST QUEUE ══════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:text="PENGUIN TOAST QUEUE"
            android:textColor="#00D9FF"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="16dp"
            android:background="#1A2535"
            android:layout_marginHorizontal="16dp">

            <Button
                android:id="@+id/btnToastQueue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#9D4EDD"
                android:text="Lanzar 4 toasts en cola (sin superposición)"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnToastQueueHaptic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="#7B2CBF"
                android:text="Cola con vibración háptica"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ══════════════ SECCIÓN: DIÁLOGOS ══════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:text="PENGUIN DIALOG"
            android:textColor="#00D9FF"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="16dp"
            android:background="#1A2535"
            android:layout_marginHorizontal="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnDialogConfirm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:backgroundTint="#00D9FF"
                    android:text="Confirmar"
                    android:textColor="#0F1923"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnDialogDelete"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:backgroundTint="#FF2E63"
                    android:text="Eliminar"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnDialogWarning"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:backgroundTint="#FFB703"
                    android:text="Advertencia"
                    android:textColor="#0F1923"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnDialogLogout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:backgroundTint="#6C757D"
                    android:text="Logout"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- ══════════════ SECCIÓN: INFO DIALOG ══════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:text="PENGUIN INFO DIALOG"
            android:textColor="#00D9FF"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="16dp"
            android:background="#1A2535"
            android:layout_marginHorizontal="16dp"
            android:weightSum="3">

            <Button
                android:id="@+id/btnInfoSuccess"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:backgroundTint="#00FF88"
                android:text="Éxito"
                android:textColor="#0F1923"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnInfoInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:backgroundTint="#00D9FF"
                android:text="Info"
                android:textColor="#0F1923"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnInfoWarning"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:backgroundTint="#FFB703"
                android:text="Aviso"
                android:textColor="#0F1923"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ══════════════ SECCIÓN: LOADING ══════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:text="PENGUIN LOADING DIALOG"
            android:textColor="#00D9FF"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="16dp"
            android:background="#1A2535"
            android:layout_marginHorizontal="16dp">

            <Button
                android:id="@+id/btnLoading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#00D9FF"
                android:text="Mostrar Loading (3 segundos)"
                android:textColor="#0F1923"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnLoadingWithSub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="#9D4EDD"
                android:text="Loading con sub-mensaje cambiante"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ══════════════ SECCIÓN: BOTTOM SHEET ══════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:text="PENGUIN SHEET"
            android:textColor="#00D9FF"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="16dp"
            android:background="#1A2535"
            android:layout_marginHorizontal="16dp">

            <Button
                android:id="@+id/btnSheet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#00D9FF"
                android:text="Abrir Bottom Sheet"
                android:textColor="#0F1923"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnSheetCustomColors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="#7B2CBF"
                android:text="Sheet con colores personalizados"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ══════════════ SECCIÓN: HAPTIC ══════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:text="PENGUIN HAPTIC"
            android:textColor="#00D9FF"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="16dp"
            android:background="#1A2535"
            android:layout_marginHorizontal="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnHapticSuccess"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:backgroundTint="#00FF88"
                    android:text="Éxito"
                    android:textColor="#0F1923"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnHapticError"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:backgroundTint="#FF2E63"
                    android:text="Error"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnHapticWarning"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:backgroundTint="#FFB703"
                    android:text="Advertencia"
                    android:textColor="#0F1923"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnHapticCritical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:backgroundTint="#6C757D"
                    android:text="Crítico"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- ══════════════ SECCIÓN: PENGUIN UI FACADE ══════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:text="PENGUIN UI (FACHADA UNIFICADA)"
            android:textColor="#00D9FF"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="16dp"
            android:background="#1A2535"
            android:layout_marginHorizontal="16dp">

            <Button
                android:id="@+id/btnFacadeToast"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#00D9FF"
                android:text="PenguinUI.success(ctx, msg)"
                android:textColor="#0F1923"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnFacadeDialog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="#9D4EDD"
                android:text="PenguinUI.confirmDialog(...)"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnFacadeSheet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="#7B2CBF"
                android:text="PenguinUI.sheet(...).build().show()"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ══════════════ SECCIÓN: PENGUIN THEME ══════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:text="PENGUIN THEME (SISTEMA DE TEMAS)"
            android:textColor="#00D9FF"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="16dp"
            android:background="#1A2535"
            android:layout_marginHorizontal="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Cambia el tema y luego toca cualquier componente arriba para ver el efecto."
                android:textColor="#B0B0B0"
                android:textSize="12sp"
                android:gravity="center" />

            <Button
                android:id="@+id/btnThemeNeo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#0F3460"
                android:text="🔵  NEO (Default) — restaurar"
                android:textColor="#00D9FF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnThemeGlass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="#1A2535"
                android:text="🪟  GLASS 75% — semitransparente"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnThemeGlassAccent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="#6200EE"
                android:text="🎨  GLASS + acento morado + esquinas rectas"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnThemeDemo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="#00FF88"
                android:text="Mostrar Toast + Dialog con tema activo"
                android:textColor="#0F1923"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
