<?xml version="1.0" encoding="utf-8"?>
<!-- Layout para Info Dialog - Diálogo de solo información con botón OK -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/infoDialogContainer"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:minWidth="320dp"
    app:cardBackgroundColor="@color/dialog_bg_secondary"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="0dp">

        <!-- Header con ícono -->
        <LinearLayout
            android:id="@+id/infoHeaderContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <!-- Ícono del diálogo (círculo con gradiente) -->
            <ImageView
                android:id="@+id/infoDialogIcon"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_dialog_icon"
                android:padding="16dp"
                android:contentDescription="Info icon"
                android:visibility="visible" />

            <!-- Título del diálogo -->
            <TextView
                android:id="@+id/infoDialogTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:text="Información"
                android:textColor="@color/dialog_text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/comic_neu_bold"
                android:gravity="center"
                android:maxLines="2"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Divider línea decorativa cyan -->
        <View
            android:layout_width="60dp"
            android:layout_height="3dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_dialog_accent_line" />

        <!-- Contenedor del mensaje -->
        <TextView
            android:id="@+id/infoDialogMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="24dp"
            android:text="Este es un mensaje informativo. Aquí va la descripción detallada de la información que se desea comunicar."
            android:textColor="@color/dialog_text_secondary"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:gravity="center"
            android:fontFamily="sans-serif"
            android:minLines="2"
            android:maxLines="6" />

        <!-- Botón OK -->
        <LinearLayout
            android:id="@+id/infoButtonContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="20dp"
            android:gravity="center">

            <!-- Botón OK (único botón) -->
            <Button
                android:id="@+id/btnOk"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:maxWidth="200dp"
                android:minWidth="120dp"
                android:background="@drawable/bg_dialog_button_primary"
                android:text="Aceptar"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/comic_neu_bold"
                android:textAllCaps="false"
                android:elevation="4dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
