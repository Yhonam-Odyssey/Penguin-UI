<?xml version="1.0" encoding="utf-8"?>
<!-- Spinner de carga con gradiente rotatorio -->
<rotate xmlns:android="http://schemas.android.com/apk/res/android"
    android:fromDegrees="0"
    android:toDegrees="360"
    android:pivotX="50%"
    android:pivotY="50%"
    android:duration="1000">

    <shape
        android:shape="ring"
        android:innerRadiusRatio="3"
        android:thicknessRatio="10"
        android:useLevel="false">

        <!-- Gradiente circular cyan → púrpura -->
        <gradient
            android:type="sweep"
            android:startColor="@color/loading_spinner_primary"
            android:centerColor="@color/dialog_accent_purple"
            android:endColor="@color/loading_spinner_secondary"
            android:useLevel="false" />

        <!-- Tamaño -->
        <size
            android:width="64dp"
            android:height="64dp" />

    </shape>

</rotate>
