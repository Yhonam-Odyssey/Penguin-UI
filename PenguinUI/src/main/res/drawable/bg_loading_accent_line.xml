<?xml version="1.0" encoding="utf-8"?>
<!-- Línea de acento con gradiente animado -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Gradiente horizontal cyan → púrpura -->
    <gradient
        android:type="linear"
        android:angle="0"
        android:startColor="@color/dialog_accent_cyan"
        android:centerColor="@color/dialog_accent_purple"
        android:endColor="@color/dialog_accent_purple_light" />

    <!-- Bordes redondeados -->
    <corners android:radius="2dp" />
</shape>
