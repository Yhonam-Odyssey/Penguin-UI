<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Gradiente vibrante púrpura → cyan -->
    <gradient
        android:type="linear"
        android:angle="135"
        android:startColor="@color/dialog_button_primary_start"
        android:endColor="@color/dialog_button_primary_end" />

    <!-- Bordes redondeados -->
    <corners android:radius="12dp" />

    <!-- Sombra sutil -->
    <padding
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp" />
</shape>
