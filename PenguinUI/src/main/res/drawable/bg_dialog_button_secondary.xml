<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Fondo sólido oscuro -->
    <solid android:color="@color/dialog_button_secondary_bg" />

    <!-- Borde cyan brillante -->
    <stroke
        android:width="2dp"
        android:color="@color/dialog_accent_cyan" />

    <!-- Bordes redondeados -->
    <corners android:radius="12dp" />

    <!-- Padding interno -->
    <padding
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp" />
</shape>
