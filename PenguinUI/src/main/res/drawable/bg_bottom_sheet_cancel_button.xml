<?xml version="1.0" encoding="utf-8"?>
<!-- Fondo del botón de cancelar -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Fondo transparente con borde -->
    <solid android:color="@color/bottom_sheet_item_bg" />

    <!-- Borde cyan -->
    <stroke
        android:width="1.5dp"
        android:color="@color/dialog_accent_cyan" />

    <!-- Bordes redondeados -->
    <corners android:radius="12dp" />
</shape>
