<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Capa de sombra/glow exterior -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="@color/dialog_glow_shadow" />
        </shape>
    </item>

    <!-- Capa principal con borde brillante -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <solid android:color="@color/dialog_bg_secondary" />
            <stroke
                android:width="2dp"
                android:color="@color/dialog_accent_cyan" />
        </shape>
    </item>

    <!-- Capa interior para efecto de profundidad -->
    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="@color/dialog_bg_secondary" />
        </shape>
    </item>
</layer-list>
